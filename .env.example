# ============================================================
# MenuOS — Variables de entorno
# Copia este archivo a apps/web/.env.local y llena los valores
# NUNCA subas .env.local a Git (ya está en .gitignore)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Obtén estas en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️  SOLO para Edge Functions / server-side. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Seguridad ─────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
# MIN 16 caracteres. Cambiar invalida todos los PINs existentes.
PIN_SALT=cambia_esto_por_32_chars_aleatorios_aqui

# Genera con: openssl rand -base64 32
# MIN 16 caracteres. Cambiar invalida todos los teléfonos encriptados.
PHONE_ENCRYPTION_KEY=cambia_esto_por_32_chars_aleatorios_aqui

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: https://tudominio.com o https://menuos.mx
NEXT_PUBLIC_APP_DOMAIN=menuos.mx

# ── WhatsApp (360dialog) ──────────────────────────────────────
# Obtén en: https://hub.360dialog.com → Settings → API Keys
WHATSAPP_API_KEY=tu_api_key_de_360dialog
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id

# ── Pagos — Stripe ────────────────────────────────────────────
# Obtén en: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Pagos — Conekta (México) ──────────────────────────────────
# Obtén en: https://admin.conekta.com → Developers → API Keys
CONEKTA_API_KEY=key_test_...

# ── Monitoreo ─────────────────────────────────────────────────
# Sentry: https://sentry.io → Settings → Projects → tu proyecto → DSN
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_AUTH_TOKEN=sntrys_...

# PostHog: https://app.posthog.com → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

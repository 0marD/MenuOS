# Variables de entorno para Edge Functions
# Configurar con: supabase secrets set KEY=value

# Automáticas (provistas por Supabase, no requieren configuración manual)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# WhatsApp webhook verification (opcional pero recomendado)
WHATSAPP_WEBHOOK_SECRET=tu_secret_aqui
# WhatsApp fallback API key (si no está en org_settings)
WHATSAPP_API_KEY=

# Web Push / VAPID
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@menuos.mx

# Cron Automations (secret to prevent unauthorized triggers)
CRON_SECRET=random-secret-here
PHONE_ENCRYPTION_KEY=32_char_random_string_here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
